#!/bin/sh

COMMIT_MSG=$(head -1 "$1")

if echo "$COMMIT_MSG" | grep -qE '^feat(\(.+\))?!?:'; then
  BUMP="minor"
elif echo "$COMMIT_MSG" | grep -qE '^(fix|refactor|perf|style|test|chore|build|ci|docs)(\(.+\))?!?:'; then
  BUMP="patch"
else
  echo "Error: commits must use conventional commit format"
  echo "  feat: ...     → minor bump"
  echo "  fix: ...      → patch bump"
  echo "  refactor: ... → patch bump"
  exit 1
fi

CURRENT_VERSION=$(node -p "require('./package.json').version")
MAJOR=$(echo "$CURRENT_VERSION" | cut -d. -f1)
MINOR=$(echo "$CURRENT_VERSION" | cut -d. -f2)
PATCH=$(echo "$CURRENT_VERSION" | cut -d. -f3)

if [ "$BUMP" = "minor" ]; then
  MINOR=$((MINOR + 1))
  PATCH=0
else
  PATCH=$((PATCH + 1))
fi

NEW_VERSION="$MAJOR.$MINOR.$PATCH"

sed -i "s/\"version\": \"$CURRENT_VERSION\"/\"version\": \"$NEW_VERSION\"/" package.json
git add package.json
echo "Version bumped: $CURRENT_VERSION → $NEW_VERSION ($BUMP)"
