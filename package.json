{
  "name": "@bjspdn/claude-shards",
  "version": "0.22.0",
  "description": "MCP server that gives Claude Code persistent knowledge via an Obsidian-compatible vault",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/bjspdn/claude-shards.git"
  },
  "bugs": {
    "url": "https://github.com/bjspdn/claude-shards/issues"
  },
  "homepage": "https://github.com/bjspdn/claude-shards?tab=readme-ov-file#claude-shards",
  "scripts": {
    "prepare": "husky",
    "bundle-vault": "bun scripts/bundle-vault.ts",
    "prebuild": "bun run bundle-vault",
    "build": "bunup",
    "prepublishOnly": "bun run build",
    "postinstall": "claude-shards --init",
    "preuninstall": "claude-shards --cleanup"
  },
  "bin": {
    "claude-shards": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/bun": "1.3.9",
    "bunup": "0.16.31",
    "husky": "9.1.7"
  },
  "peerDependencies": {
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@huggingface/transformers": "3.5.1",
    "@modelcontextprotocol/sdk": "1.27.1",
    "globby": "16.1.1",
    "gray-matter": "4.0.3",
    "smol-toml": "1.6.0",
    "tiktoken": "1.0.22",
    "zod": "4.3.6"
  }
}
